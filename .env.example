# DermaCare AI - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials/settings.
# 
# IMPORTANT: Keep this file private! Add '.env' to .gitignore

# --- Backend Configuration ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Security Configuration ---
# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change-this-to-a-secure-random-key-run-python-command-above
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database Configuration ---
# SQLCipher encryption key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# IMPORTANT: Changing this will make existing database unreadable!
SQLCIPHER_KEY=change-this-to-another-secure-random-key

# --- AI Engine Configuration (Ollama) ---
# Local: http://127.0.0.1:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# --- Inference Settings ---
MAX_TOKENS=1536
TEMPERATURE=0.3

# --- Cache Settings ---
CACHE_MAX_SIZE=100

# --- Logging ---
LOG_LEVEL=INFO

# --- CORS Settings (local only) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010

# --- Optional: External AI Providers ---
# GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# --- Reliability Pipeline Flags ---
RELIABILITY_PIPELINE_V2=true
ENABLE_GROQ_FALLBACK=true
ENABLE_OPENAI_FINAL_CONTINGENCY=false
# Quick mode: Groq only if true or Ollama unreachable (case-based fallback)
QUICK_ALLOW_GROQ_FALLBACK=false
PARTIAL_VALID_THRESHOLD=0.5
# Escalation toast when numeric confidence falls below this (default 0.40 = balanced)
LOW_CONFIDENCE_ESCALATION_THRESHOLD=0.40
GROQ_USAGE_CAP_RATE=0.10
# Quick mode: one JSON repair pass after a failed parse (0 disables)
QUICK_RETRY_LIMIT=1
ACCURATE_RETRY_LIMIT=2
QUICK_MODE_MAX_TOKENS=384
ACCURATE_MODE_MAX_TOKENS=1024
ACCURATE_TIME_BUDGET_SECONDS=55
ACCURATE_FINAL_FALLBACK_TIMEOUT_SECONDS=15
GROQ_MODEL=llama3-70b-8192
GROQ_MODEL_CHEAP=llama3-8b-8192
GROQ_MODEL_STRATEGY=quality
PRICE_PER_REQUEST_USD=0.05
API_DEFAULT_VERSION=v1
