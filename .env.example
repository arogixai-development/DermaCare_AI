# DermaCare AI - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials/settings.

# --- Backend Configuration ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Security Configuration ---
# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=your-secret-key-here-generate-with-python-command
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database Configuration ---
DATABASE_URL=sqlite:///backend/database/dermacare.db

# --- AI Engine Configuration (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# --- Inference Settings ---
MAX_TOKENS=1536
TEMPERATURE=0.3

# --- Cache Settings ---
CACHE_MAX_SIZE=100

# --- Logging ---
LOG_LEVEL=INFO

# --- CORS Settings (local only) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3010,http://127.0.0.1:3010

# --- Optional: External AI Providers ---
# GROQ_API_KEY=your_groq_api_key_here
