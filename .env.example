# DermaCare AI - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials/settings.

# --- Backend Configuration ---
# The port where the FastAPI/Flask backend will run
API_PORT=8000

# --- AI Engine Configuration (Ollama) ---
# The URI for your local Ollama instance (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# The specific model name you want to use (e.g., phi3, mistral, llama3)
MODEL_NAME=phi3

# --- Optional: External AI Providers ---
# If you want to use Groq for faster remote inference
# GROQ_API_KEY=your_groq_api_key_here
