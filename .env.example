# DermaCare AI - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials/settings.

# --- Backend Configuration ---
# The host and port where the FastAPI backend will run
API_HOST=0.0.0.0
API_PORT=8000

# --- AI Engine Configuration (Ollama) ---
# The URI for your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# The specific model name you want to use
OLLAMA_MODEL=llama3:8b

# --- Inference Settings ---
# Max tokens for AI response (default: 1536)
MAX_TOKENS=1536

# Temperature for AI generation (0.0-1.0, default: 0.3)
TEMPERATURE=0.3

# --- Cache Settings ---
# Max cache size for AI responses (default: 128)
CACHE_MAX_SIZE=128

# --- Logging ---
LOG_LEVEL=INFO

# --- CORS Settings ---
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# --- Optional: External AI Providers ---
# If you want to use Groq for faster remote inference
# GROQ_API_KEY=your_groq_api_key_here
